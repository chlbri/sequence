{
  "name": "@bemedev/sequence",
  "version": "1.0.0",
  "description": "A simple utility for managing sequences of timed actions in JavaScript. Provides an easy way to create and run sequences of actions with customizable delays and error handling.",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/sequence"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "sequence",
    "timed actions",
    "utility",
    "delay"
  ],
  "files": [
    "lib",
    "public"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm rm:lib && pnpm run rolldown",
    "_ci": "pnpm run config:off && pnpm run lint && pnpm run test",
    "ci": "CI_START=$(date +%s) && pnpm run _ci && pnpm run p-q && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "CI_START=$(date +%s) && pnpm run rm && pnpm run upgrade:fast && pnpm run _ci && echo \"\n✅ Admin CI takes $(($(date +%s) - CI_START))s\n\"",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "_lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run lint",
    "build:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run build",
    "p-q": "pretty-quick",
    "posttest": "pnpm run fmt && build-tests post",
    "prepare": "husky",
    "prepublishOnly": "",
    "pretest": "pnpm run build && build-tests pre",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "rinit": "pnpm clean --lockfile && pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rm": "pnpx rimraf ./node_modules ./pnpm-lock.yaml",
    "rm:lib": "pnpx rimraf ./lib",
    "rolldown": "rolldown -c",
    "test:coverage": "vitest run",
    "test": "pnpm run test:coverage",
    "test:no-type": "pnpm run test:coverage -c \"vitest.config.notype.ts\" --no-coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:ui": "vitest --ui",
    "test:type": "pnpm run test:coverage -c \"vitest.config.type.ts\" --no-coverage",
    "test:type:watch": "vitest -c \"vitest.config.type.ts\"",
    "test:watch": "vitest",
    "upgrade": "pnpm dlx @bemedev/upgrade-npm-package",
    "upgrade:fast": "pnpm up --latest"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/dev-utils": "^0.7.0",
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "rolldown": "^1.0.3",
    "size-limit": "^12.1.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@bemedev/sleep": "^0.2.2"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
